{
  "expo": {
    "name": "kaskita_app",
    "slug": "kaskita_app",
    "owner": "aryajulianda",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "kaskitaapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aryajulianda.kaskita-app",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.995599594595-cl6n078e5b9a3d4ug867c1qso2gta52e"
            ]
          }
        ],
        "NSMicrophoneUsageDescription": "Kaskita membutuhkan akses mikrofon untuk merekam transaksi suara.",
        "NSPhotoLibraryUsageDescription": "Kaskita membutuhkan akses galeri untuk memilih foto profil dan lampiran.",
        "NSUserTrackingUsageDescription": "Kaskita tidak menggunakan data pelacakan untuk iklan, izin ini hanya untuk kompatibilitas platform jika dibutuhkan."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "package": "com.aryajulianda.kaskita_app",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-audio",
      "expo-image-picker",
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",
      "expo-notifications",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.995599594595-cl6n078e5b9a3d4ug867c1qso2gta52e"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cca0a8e0-35ee-427f-bd51-88562094000f"
      }
    }
  }
}
